# PostgreSQL 17 HA cluster configuration.
#
# Format:
#   [section]
#   key="value"
#
# 节点级覆盖配置是可选的。值留空表示继承全局配置。
# [node.*.tags] 会直接渲染为 Patroni tags。

[cluster]
name="pg17-ha"
scope="pg17-ha"

[deploy]
install_root="/opt/pg-ha-installer"
ssh_user="root"
ssh_password="123456"
ssh_key=""
ssh_port="22"

[os]
timezone="Asia/Shanghai"
enable_chrony="true"
disable_transparent_hugepage="true"
apply_sysctl="true"
apply_limits="true"
open_firewall_ports="true"
manage_selinux="false"

[etcd]
version="v3.6.12"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
client_port="2379"
peer_port="2380"
data_dir="/pg/etcd"
config_file="/etc/etcd.conf.yml"
bin_dir="/usr/local/bin"

[postgresql]
# PostgreSQL 实例身份和连接入口。这里的参数不是 postgresql.conf 参数。
version="17.10"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
port="5432"
os_user="postgres"
database="postgres"

[postgresql.install]
# 安装路径和存储路径。这里描述软件与文件布局，不会写入 postgresql.conf。
prefix="/pg/pghome"
data_dir="/pgdata/pg17"
wal_archive="/pgwal/archive_wals"
backup_dir="/pgbak"
# PostgreSQL 源码编译选项。--with-python 用于支持 PL/Python，需要 python3-devel。
# 生产上如需 lz4/zstd 压缩，可先补齐 lz4-devel/libzstd-devel 后再追加对应选项。
configure_options="--with-openssl --with-zlib --with-uuid=e2fs --with-python"

[postgresql.auth]
# 生产部署前必须修改这些默认密码。
superuser="postgres"
superpass="ChangeMe_pg17_super"
replication_user="replicator"
replication_pass="ChangeMe_pg17_repl"
rewind_user="rewind"
rewind_pass="ChangeMe_pg17_rewind"

[postgresql.conf]
# 这里的参数会进入 Patroni bootstrap.dcs.postgresql.parameters，
# 由 Patroni 管理并最终成为 PostgreSQL 配置。
listen_addresses="*"
max_connections="300"
shared_buffers="4GB"
effective_cache_size="12GB"
maintenance_work_mem="512MB"
work_mem="16MB"
wal_level="replica"
wal_log_hints="on"
max_wal_senders="10"
max_replication_slots="10"
wal_keep_size="2GB"
max_wal_size="8GB"
checkpoint_completion_target="0.9"
hot_standby="on"
hot_standby_feedback="on"
password_encryption="scram-sha-256"
shared_preload_libraries="pg_stat_statements"
pg_stat_statements.max="10000"
pg_stat_statements.track="all"
logging_collector="on"
log_directory="log"
log_filename="postgresql-%Y-%m-%d.log"
log_line_prefix="%m [%p] %u@%d %r %a "
log_min_duration_statement="1000"
archive_mode="on"
# archive_command 默认由 pg_probackup 管理。%p 是 WAL 文件路径，%f 是 WAL 文件名。
archive_command="/usr/local/bin/pg_probackup archive-push -B /pgbak/pg_probackup --instance pg17-ha --wal-file-path=%p --wal-file-name=%f"
unix_socket_directories="/var/run/postgresql"

[pg_probackup]
# pg_probackup 用于 WAL 归档和周期备份。源码包会下载到 packages/ 目录，
# 内网部署时会从该源码包编译安装。
version="2.5.16"
backup_dir="/pgbak/pg_probackup"
instance="pg17-ha"
binary="/usr/local/bin/pg_probackup"
retention_redundancy="4"
retention_window="30"
cron_minute="30"
cron_hour="1"
# 每周几做全量备份。0 表示星期天，1-6 表示星期一到星期六。
full_backup_day="0"
# 每天非全量日执行的备份模式。PAGE 依赖 WAL 归档，适合增量备份。
incremental_mode="PAGE"
backup_user="postgres"

[patroni]
version="3.0.4"
port="8008"
home="/etc/patroni"
log_dir="/var/log/patroni"

[patroni.dcs]
ttl="30"
loop_wait="10"
retry_timeout="10"
maximum_lag_on_failover="1048576"
use_pg_rewind="true"
use_slots="true"

[patroni.sync]
# “始终保持一个同步从库”的推荐配置：
#   synchronous_mode=true          开启同步复制管理
#   synchronous_mode_strict=true   没有可用同步从库时，主库写入会等待
#   synchronous_node_count=1       同时保持 1 个同步从库
#
# 注意：strict=true 是强一致性取向。如果所有可作为同步从库的节点都不可用，
# 写请求会阻塞，直到同步从库恢复或人工调整配置。
synchronous_mode="true"
synchronous_mode_strict="true"
synchronous_node_count="1"

[vip]
address="10.0.0.124"
cidr="24"
device="ens33"
label="pgvip"

[node.pg01]
# prefix=""
# data_dir=""
# wal_archive=""
# backup_dir=""
# etcd_data_dir=""
# patroni_home=""
# patroni_log_dir=""

[node.pg01.tags]
# nofailover=false 表示该节点允许被提升为主库；true 表示永不自动提升。
# noloadbalance=false 表示该节点允许承担读流量；true 表示不参与读负载。
# clonefrom=false 表示该节点不是优先的复制源；true 表示可优先作为新副本的基础备份来源。
# nosync=false 表示该节点允许被选为同步从库；true 表示该节点只能作为异步从库。
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg02]
# 留空表示继承 [postgresql.install]、[etcd] 和 [patroni] 的全局路径。

[node.pg02.tags]
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg03]
# 留空表示继承 [postgresql.install]、[etcd] 和 [patroni] 的全局路径。

[node.pg03.tags]
# 所有本地副本都可作为同步从库时保持 nosync=false。
# 如果该节点是跨机房容灾节点或链路延迟较高，不希望它影响主库提交延迟，
# 可设置 nosync=true，让它固定作为异步从库。
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"
