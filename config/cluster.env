# Cluster identity
CLUSTER_NAME="pg17-ha"
SCOPE="pg17-ha"

# PostgreSQL 17 latest minor verified from the official PostgreSQL source tree.
POSTGRES_VERSION="17.10"
POSTGRES_PORT="5432"
PATRONI_PORT="8008"

# etcd
ETCD_VERSION="v3.6.12"
ETCD_CLIENT_PORT="2379"
ETCD_PEER_PORT="2380"

# Three nodes: name:ip. Keep names DNS-safe and unique.
CLUSTER_NODES=(
  "pg01:10.0.0.121"
  "pg02:10.0.0.122"
  "pg03:10.0.0.123"
)

# Optional VIP. Leave VIP_ADDRESS empty to disable VIP callback.
VIP_ADDRESS=""
VIP_CIDR="24"
VIP_DEVICE="eth0"
VIP_LABEL="pgvip"

# Paths
INSTALL_ROOT="/opt/pg-ha-installer"
PG_PREFIX="/pg/pghome"
PG_DATA="/pgdata/pg17"
PG_WAL_ARCHIVE="/pgwal/archive_wals"
PG_BACKUP="/pgbak"
ETCD_DATA="/pg/etcd"
PATRONI_HOME="/etc/patroni"
PATRONI_LOG_DIR="/var/log/patroni"

# Users and credentials.
# Change these before production deployment.
POSTGRES_OS_USER="postgres"
POSTGRES_SUPERUSER="postgres"
POSTGRES_SUPERPASS="ChangeMe_pg17_super"
REPLICATION_USER="replicator"
REPLICATION_PASS="ChangeMe_pg17_repl"
REWIND_USER="rewind"
REWIND_PASS="ChangeMe_pg17_rewind"

# Remote deployment transport. Prefer SSH key in production.
SSH_USER="root"
SSH_PASSWORD="123456"
SSH_KEY=""
SSH_PORT="22"

# Tuning baseline. These are conservative defaults and should be reviewed
# against actual CPU, memory, storage, workload, and SLA.
MAX_CONNECTIONS="300"
SHARED_BUFFERS="4GB"
EFFECTIVE_CACHE_SIZE="12GB"
MAINTENANCE_WORK_MEM="512MB"
WORK_MEM="16MB"
WAL_KEEP_SIZE="2GB"
MAX_WAL_SIZE="8GB"

# Replication mode. Use "on" only when the business accepts commit latency
# in exchange for lower RPO.
SYNCHRONOUS_MODE="false"
SYNCHRONOUS_MODE_STRICT="false"
