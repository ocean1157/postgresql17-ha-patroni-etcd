# PostgreSQL 17 HA cluster configuration.
#
# Format:
#   [section]
#   key="value"
#
# Node-specific override sections are optional. Empty values inherit global
# settings. Node tags map directly to Patroni tags.

[cluster]
name="pg17-ha"
scope="pg17-ha"

[deploy]
install_root="/opt/pg-ha-installer"
ssh_user="root"
ssh_password="123456"
ssh_key=""
ssh_port="22"

[os]
timezone="Asia/Shanghai"
enable_chrony="true"
disable_transparent_hugepage="true"
apply_sysctl="true"
apply_limits="true"
open_firewall_ports="true"
manage_selinux="false"

[etcd]
version="v3.6.12"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
client_port="2379"
peer_port="2380"
data_dir="/pg/etcd"
config_file="/etc/etcd.conf.yml"
bin_dir="/usr/local/bin"

[postgresql]
# Instance identity and connection surface. Values here are not PostgreSQL GUCs
# unless noted in [postgresql.conf].
version="17.10"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
port="5432"
os_user="postgres"
database="postgres"

[postgresql.install]
# Installation and storage paths. These are filesystem layout parameters, not
# postgresql.conf parameters.
prefix="/pg/pghome"
data_dir="/pgdata/pg17"
wal_archive="/pgwal/archive_wals"
backup_dir="/pgbak"

[postgresql.auth]
# Change these before production deployment.
superuser="postgres"
superpass="ChangeMe_pg17_super"
replication_user="replicator"
replication_pass="ChangeMe_pg17_repl"
rewind_user="rewind"
rewind_pass="ChangeMe_pg17_rewind"

[postgresql.conf]
# Parameters below are rendered into Patroni bootstrap.dcs.postgresql.parameters
# and are managed as PostgreSQL configuration.
listen_addresses="*"
max_connections="300"
shared_buffers="4GB"
effective_cache_size="12GB"
maintenance_work_mem="512MB"
work_mem="16MB"
wal_level="replica"
wal_log_hints="on"
max_wal_senders="10"
max_replication_slots="10"
wal_keep_size="2GB"
max_wal_size="8GB"
checkpoint_completion_target="0.9"
hot_standby="on"
hot_standby_feedback="on"
password_encryption="scram-sha-256"
shared_preload_libraries="pg_stat_statements"
pg_stat_statements.max="10000"
pg_stat_statements.track="all"
logging_collector="on"
log_directory="log"
log_filename="postgresql-%Y-%m-%d.log"
log_line_prefix="%m [%p] %u@%d %r %a "
log_min_duration_statement="1000"
archive_mode="on"
archive_command="test ! -f /pgwal/archive_wals/%f && cp %p /pgwal/archive_wals/%f"
unix_socket_directories="/var/run/postgresql"

[patroni]
version="3.0.4"
port="8008"
home="/etc/patroni"
log_dir="/var/log/patroni"

[patroni.dcs]
ttl="30"
loop_wait="10"
retry_timeout="10"
maximum_lag_on_failover="1048576"
use_pg_rewind="true"
use_slots="true"

[patroni.sync]
# For "always keep one synchronous standby":
#   synchronous_mode=true
#   synchronous_mode_strict=true
#   synchronous_node_count=1
#
# strict=true means writes will wait/block when no eligible synchronous standby
# is available. That is the expected tradeoff when the requirement is to always
# maintain one synchronous standby.
synchronous_mode="true"
synchronous_mode_strict="true"
synchronous_node_count="1"

[vip]
address="10.0.0.124"
cidr="24"
device="ens33"
label="pgvip"

[node.pg01]
# prefix=""
# data_dir=""
# wal_archive=""
# backup_dir=""
# etcd_data_dir=""
# patroni_home=""
# patroni_log_dir=""

[node.pg01.tags]
# nofailover=false allows this node to become primary.
# noloadbalance=false allows read load balancing.
# clonefrom=false means this node is not specially preferred as clone source.
# nosync=false allows this node to be selected as a synchronous standby.
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg02]
# Leave blank to inherit [postgresql], [etcd], and [patroni] global paths.

[node.pg02.tags]
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg03]
# Leave blank to inherit [postgresql], [etcd], and [patroni] global paths.

[node.pg03.tags]
# Keep this false when every replica can be the synchronous standby.
# Set nosync=true if this node must stay asynchronous, for example a DR node
# across a high-latency link.
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"
