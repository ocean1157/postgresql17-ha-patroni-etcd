# PostgreSQL 17 HA cluster configuration.
#
# Format:
#   [section]
#   key="value"
#
# Node-specific override sections are optional. For example, values under
# [node.pg02] override global paths only on pg02. Leave them empty to inherit.

[cluster]
name="pg17-ha"
scope="pg17-ha"

[deploy]
install_root="/opt/pg-ha-installer"
ssh_user="root"
ssh_password="123456"
ssh_key=""
ssh_port="22"

[os]
timezone="Asia/Shanghai"
enable_chrony="true"
disable_transparent_hugepage="true"
apply_sysctl="true"
apply_limits="true"
open_firewall_ports="true"
manage_selinux="false"

[etcd]
version="v3.6.12"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
client_port="2379"
peer_port="2380"
data_dir="/pg/etcd"
config_file="/etc/etcd.conf.yml"
bin_dir="/usr/local/bin"

[postgresql]
version="17.10"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
port="5432"
os_user="postgres"
prefix="/pg/pghome"
data_dir="/pgdata/pg17"
wal_archive="/pgwal/archive_wals"
backup_dir="/pgbak"
database="postgres"
superuser="postgres"
superpass="ChangeMe_pg17_super"
replication_user="replicator"
replication_pass="ChangeMe_pg17_repl"
rewind_user="rewind"
rewind_pass="ChangeMe_pg17_rewind"
max_connections="300"
shared_buffers="4GB"
effective_cache_size="12GB"
maintenance_work_mem="512MB"
work_mem="16MB"
wal_keep_size="2GB"
max_wal_size="8GB"
synchronous_mode="false"
synchronous_mode_strict="false"

[patroni]
version="3.0.4"
port="8008"
home="/etc/patroni"
log_dir="/var/log/patroni"

[vip]
address="10.0.0.124"
cidr="24"
device="ens33"
label="pgvip"

[node.pg01]
# prefix=""
# data_dir=""
# wal_archive=""
# backup_dir=""
# etcd_data_dir=""
# patroni_home=""
# patroni_log_dir=""

[node.pg02]
# Leave blank to inherit [postgresql], [etcd], and [patroni] global paths.

[node.pg03]
# Leave blank to inherit [postgresql], [etcd], and [patroni] global paths.
