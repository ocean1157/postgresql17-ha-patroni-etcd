# PostgreSQL 17 高可用集群配置
#
# 配置规则：
#   1. 每个配置项必须独占一行，格式为 key="value"。
#   2. 不要在行尾注释后继续写 key=value；“#”之后的内容会被脚本忽略。
#   3. true/false 和数字也应保留双引号，以保持格式统一。
#   4. “【必填】”参数必须保留有效值；“【条件必填】”参数在对应功能启用时必须填写。
#   5. 正式部署前必须填写 [postgresql.auth] 中的三个密码。

[cluster]
# 集群显示名称，用于标识本套 PostgreSQL 高可用集群。
name="pg17-ha"
# Patroni 的 DCS 作用域；同一 etcd 中不同集群必须使用不同 scope。
scope="pg17-ha"

[deploy]
# 安装包上传到目标节点后的临时工作目录。
install_root="/opt/pg-ha-installer"
# 【必填】连接各目标节点所用的 SSH 用户；安装过程通常需要 root 权限。
ssh_user="root"
# 【条件必填】使用密码认证时填写；使用密钥或已配置免密登录时可留空。
ssh_password=""
# 【条件必填】使用指定私钥认证时填写；使用密码或默认密钥时可留空。
ssh_key=""
# 【必填】目标节点的 SSH 服务端口，必须与各节点 sshd 的实际监听端口一致。
ssh_port="22"
# 并行部署的最大节点数；数值越大部署越快，但会增加控制机负载。
parallel_jobs="3"

[os]
# 目标节点系统时区，使用 IANA 时区名称。
timezone="Asia/Shanghai"
# 是否安装、启用并配置 chrony 时间同步服务。
enable_chrony="true"
# 是否禁用透明大页（THP），以减少 PostgreSQL 延迟抖动。
disable_transparent_hugepage="true"
# 是否应用脚本内置的数据库主机 sysctl 内核参数。
apply_sysctl="true"
# 是否应用 PostgreSQL 用户的资源限制（limits）。
apply_limits="true"
# 是否通过 firewalld 自动放行 PostgreSQL、Patroni 和 etcd 所需端口。
open_firewall_ports="true"
# 是否在/etc/selinux/config文件中把SELinux 调成 permissive，并执行 setenforce 0
manage_selinux="permissive"

[repository]
# yum/dnf 软件源。可填仓库 baseurl、.repo 文件 URL/本地路径，或逗号分隔的 repo ID。
# 留空时使用目标系统当前已启用的软件源。
yum_source=""
# 需要禁用的 yum/dnf repo ID，多个 ID 使用英文逗号分隔；留空表示不额外禁用。
yum_disable_repos=""
# pip 软件源。可填镜像根地址，或完整参数（如 --index-url ... --trusted-host ...）。
# 留空时使用 pip 默认配置的软件源。
pip_source=""
# 安装模式：auto=优先在线、失败后使用 packages 离线包；true=仅离线；false=仅在线。
offline_install="auto"

[etcd]
# etcd 版本；须与 packages 中的离线安装包版本一致，通常包含前缀 v。
version="v3.6.12"
# 【必填】etcd 成员列表，格式为“节点名:IP”，多个成员使用英文逗号分隔。
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
# etcd 客户端通信端口，供 Patroni 和 etcdctl 访问。
client_port="2379"
# etcd 成员间 Raft 通信端口。
peer_port="2380"
# etcd 数据目录；节点级 [node.<name>] 配置可覆盖此值。
data_dir="/home/postgres/etcd"
# 【必填】etcd 日志目录；必须为绝对路径。
log_dir="/home/postgres/log/etcd"
# etcd 生成配置文件的完整路径。
config_file="/home/postgres/etcd/etcd.conf.yml"
# etcd、etcdctl 可执行文件的安装目录。
bin_dir="/home/postgres/etcd/bin"

[postgresql]
# PostgreSQL 源码版本；须与 packages 中的源码包版本一致。
version="17.10"
# 【必填】PostgreSQL/Patroni 节点列表，格式为“节点名:IP”，顺序中的首节点用于初始化。
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"
# 【必填】PostgreSQL 数据库监听端口。
port="5432"
# 【必填】运行 PostgreSQL、Patroni 和 etcd 服务的操作系统用户。
os_user="postgres"
# 默认连接数据库，也是 pg_cron 默认执行任务的数据库。
database="postgres"

[postgresql.install]
# 【必填】PostgreSQL 安装前缀，即 PGHOME；节点级 prefix 可覆盖此值。
prefix="/home/postgres/pghome"
# 【必填】PostgreSQL 数据目录，即 PGDATA；节点级 data_dir 可覆盖此值。
data_dir="/data/postgres/pgdata"
# 传给 PostgreSQL 源码 configure 的编译选项；安装和离线包下载会据此自动选择开发依赖，并在编译前预检。
configure_options="--with-openssl --with-zlib --with-uuid=e2fs --with-python"

[postgresql.auth]
# PostgreSQL 超级用户名称。
superuser="postgres"
# 【必填】超级用户密码；部署脚本会强制检查，不能为空。明文保存，请限制本文件权限。
superpass=""
# 流复制专用用户名称。
replication_user="replicator"
# 【必填】流复制用户密码；部署脚本会强制检查，不能为空。
replication_pass=""
# pg_rewind 专用用户名称。
rewind_user="rewind"
# 【必填】pg_rewind 用户密码；部署脚本会强制检查，不能为空。
rewind_pass=""
# 【必填】仅保存流复制和 pg_rewind 凭据的 libpq 密码文件；必须为绝对路径。
pgpass_file="/home/postgres/.pgpass"

[postgresql.conf]
# PostgreSQL 监听地址；“*”表示监听所有可用网络接口。
listen_addresses="*"
# max_connections、shared_buffers、effective_cache_size、maintenance_work_mem、
# max_worker_processes、max_parallel_workers、max_parallel_workers_per_gather
# 默认由部署发起节点按 CPU 和内存统一计算；需要固定值时可在本节显式添加对应参数。
# 每个排序、哈希操作可使用的基础内存上限，可能被并发操作多次分配。
work_mem="16MB"
# WAL 记录级别；replica 支持物理流复制和归档恢复。
wal_level="replica"
# 是否记录用于 pg_rewind 的 WAL 提示位；启用可支持故障节点回切。
wal_log_hints="on"
# 允许同时存在的 WAL 发送进程最大数量。
max_wal_senders="10"
# 允许创建的复制槽最大数量。
max_replication_slots="10"
# 为备用节点尽量保留的 WAL 大小，降低短时复制中断后重建的概率。
wal_keep_size="2GB"
# 检查点之间允许增长到的 WAL 建议上限。
max_wal_size="8GB"
# 检查点写入在检查点间隔中分摊的比例，0.9 表示尽量平滑写入。
checkpoint_completion_target="0.9"
# 是否允许备库在恢复期间接受只读查询。
hot_standby="on"
# 备库是否向主库反馈查询状态，以降低查询因清理旧版本而被取消的概率。
hot_standby_feedback="on"
# 新密码的加密方式；scram-sha-256 比 md5 更安全。
password_encryption="scram-sha-256"
# PostgreSQL 启动时预加载的扩展库，多个库使用英文逗号分隔。
shared_preload_libraries="pg_cron,pg_stat_statements"
# pg_stat_statements 最多跟踪的不同 SQL 语句数量。
pg_stat_statements.max="10000"
# pg_stat_statements 跟踪范围；all 表示包含嵌套语句。
pg_stat_statements.track="all"
# pg_cron 扩展元数据及后台工作进程所在的数据库名称。
cron.database_name="postgres"
# 是否启用日志收集器，将 stderr 日志重定向到日志文件。
logging_collector="on"
# PostgreSQL 日志目录；相对路径以 PGDATA 为基准。
log_directory="log"
# 日志文件名格式，支持 strftime 时间占位符。
log_filename="postgresql-%Y-%m-%d.log"
# 每条日志的前缀格式：时间、进程、用户、数据库、客户端和应用名。
log_line_prefix="%m [%p] %u@%d %r %a "
# 记录执行时间达到该阈值的 SQL，单位毫秒；-1 表示禁用。
log_min_duration_statement="1000"
# 是否开启 WAL 归档；归档命令由脚本根据 pg_probackup 配置生成。
archive_mode="always"

[pg_probackup]
# pg_probackup 版本；须与 packages 中的源码包版本一致。
version="2.5.16"
# 定时备份执行节点：full=所有 PostgreSQL 节点，leader=仅当前主库，
# standby=除当前主库外的所有备库；也可填写 [postgresql].nodes 中的节点名称。
backup_host="leader"
# 备份仓库根目录，应位于容量充足且可靠的存储上。
backup_dir="/data/postgres/pgbak"
# 【必填】pg_probackup 任务日志目录；必须为绝对路径。
log_dir="/home/postgres/log/pg_probackup"
# pg_probackup 实例名称，用于区分同一备份仓库中的数据库实例。
instance="pg17-ha"
# pg_probackup 可执行文件的安装路径。
binary="/usr/local/bin/pg_probackup"
# 自动生成的备份任务脚本路径。
job_script="/usr/local/bin/pg_ha_probackup.sh"
# 至少保留的有效备份链数量。
retention_redundancy="4"
# 备份保留窗口，单位为天。
retention_window="30"
# 定时备份任务的分钟字段，取值 0-59。
cron_minute="30"
# 定时备份任务的小时字段，取值 0-23。
cron_hour="1"
# 每周执行全量备份的星期，取值 0-6，0 表示星期日。
full_backup_day="0"
# 非全量日使用的增量备份模式，如 PAGE、DELTA 或 PTRACK。
incremental_mode="PAGE"
# 执行备份及连接 PostgreSQL 所用的数据库用户。
backup_user="postgres"

[pg_cron]
# pg_cron 扩展版本；须与 packages 中的源码包版本一致。
version="1.6.7"

[pg_repack]
# pg_repack 扩展版本；1.5.3 支持 PostgreSQL 17。
version="1.5.3"

[patroni]
# Patroni Python 包版本；须与离线 Python 包版本一致。
version="3.0.4"
# Patroni REST API 监听端口，供 patronictl、健康检查和集群成员访问。
port="8008"
# Patroni 配置及辅助脚本目录；节点级 patroni_home 可覆盖此值。
home="/home/postgres/patroni"
# Patroni 日志目录；节点级 patroni_log_dir 可覆盖此值。
log_dir="/home/postgres/log/patroni"
# Patroni Python 虚拟环境目录。
venv="/home/postgres/patroni-venv"
# patroni、patronictl 命令的安装目录。
bin_dir="/home/postgres/patroni/bin"

[patroni.dcs]
# Leader 锁的存活时间（秒）；Leader 未续租超过该时间后锁会失效。
ttl="30"
# Patroni 主循环执行间隔（秒）。
loop_wait="10"
# DCS 或 PostgreSQL 操作的重试超时时间（秒），通常应小于 ttl。
retry_timeout="10"
# 允许参与故障切换的备库最大复制延迟，单位字节。
maximum_lag_on_failover="1048576"
# 是否使用 pg_rewind 将旧主库快速恢复为备库。
use_pg_rewind="true"
# 是否使用永久复制槽保护备库所需 WAL。
use_slots="true"

[patroni.sync]
# 是否启用同步复制模式，保证至少按配置数量的同步备库确认事务。
synchronous_mode="true"
# 严格同步模式；没有可用同步备库时也拒绝提交，可能牺牲可用性以避免数据丢失。
synchronous_mode_strict="true"
# 需要同步确认的备库数量；应小于可用备库总数。
synchronous_node_count="1"

[vip]
# 【条件必填】启用 VIP 漂移时填写主节点持有的虚拟 IP；留空可禁用 VIP 功能。
address="10.0.0.124"
# 【条件必填】启用 VIP 时填写其 CIDR 前缀长度。
cidr="24"
# 【条件必填】启用 VIP 时填写目标网卡名称，且该网卡必须在所有数据库节点上存在。
device="ens33"
# 添加虚拟 IP 时使用的接口别名标签。
label="pgvip"

[node.pg01]
# 以下参数用于仅覆盖 pg01 的全局配置；保持注释表示继承对应全局值。
# PostgreSQL 安装前缀，覆盖 [postgresql.install] prefix。
# prefix=""
# PostgreSQL 数据目录，覆盖 [postgresql.install] data_dir。
# data_dir=""
# etcd 数据目录，覆盖 [etcd] data_dir。
# etcd_data_dir=""
# Patroni 配置目录，覆盖 [patroni] home。
# patroni_home=""
# Patroni 日志目录，覆盖 [patroni] log_dir。
# patroni_log_dir=""

[node.pg01.tags]
# true 表示 pg01 不允许成为故障切换候选节点。
nofailover="false"
# true 表示 pg01 不参与客户端读负载均衡。
noloadbalance="false"
# true 表示创建新备库时优先允许从 pg01 克隆。
clonefrom="false"
# true 表示 pg01 不会被选为同步复制备库。
nosync="false"

[node.pg02]
# 以下参数用于仅覆盖 pg02 的全局配置；保持注释表示继承对应全局值。
# PostgreSQL 安装前缀，覆盖 [postgresql.install] prefix。
# prefix=""
# PostgreSQL 数据目录，覆盖 [postgresql.install] data_dir。
# data_dir=""
# etcd 数据目录，覆盖 [etcd] data_dir。
# etcd_data_dir=""
# Patroni 配置目录，覆盖 [patroni] home。
# patroni_home=""
# Patroni 日志目录，覆盖 [patroni] log_dir。
# patroni_log_dir=""

[node.pg02.tags]
# true 表示 pg02 不允许成为故障切换候选节点。
nofailover="false"
# true 表示 pg02 不参与客户端读负载均衡。
noloadbalance="false"
# true 表示创建新备库时优先允许从 pg02 克隆。
clonefrom="false"
# true 表示 pg02 不会被选为同步复制备库。
nosync="false"

[node.pg03]
# 以下参数用于仅覆盖 pg03 的全局配置；保持注释表示继承对应全局值。
# PostgreSQL 安装前缀，覆盖 [postgresql.install] prefix。
# prefix=""
# PostgreSQL 数据目录，覆盖 [postgresql.install] data_dir。
# data_dir=""
# etcd 数据目录，覆盖 [etcd] data_dir。
# etcd_data_dir=""
# Patroni 配置目录，覆盖 [patroni] home。
# patroni_home=""
# Patroni 日志目录，覆盖 [patroni] log_dir。
# patroni_log_dir=""

[node.pg03.tags]
# true 表示 pg03 不允许成为故障切换候选节点。
nofailover="false"
# true 表示 pg03 不参与客户端读负载均衡。
noloadbalance="false"
# true 表示创建新备库时优先允许从 pg03 克隆。
clonefrom="false"
# true 表示 pg03 不会被选为同步复制备库。
nosync="false"
