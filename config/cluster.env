# PostgreSQL 17 HA cluster configuration.
#
# Format:
#   [section]
#   key="value"
#
# 节点级覆盖配置是可选的。值留空表示继承全局配置。
# [node.*.tags] 会直接渲染为 Patroni tags。

[cluster]
name="pg17-ha"  ##应用于etcd.conf.yml配置文件中
scope="pg17-ha"   ##应用于patroni.yml配置文件

[deploy]
install_root="/opt/pg-ha-installer"
ssh_user="root"  ##【必填】部署 SSH 用户。脚本需要用该用户登录所有节点并执行安装、建目录、写 systemd 等操作；建议使用 root，或确保该用户具备等价权限。
# 使用密码登录时填写；使用 ssh_key 或免密登录时留空。
ssh_password=""  ##【必填】：密码登录时填写；如果使用 ssh_key 或已经配置免密登录，可以留空。
ssh_key=""  ##【必填】：密钥登录时填写私钥路径；如果使用 ssh_password 或已经配置免密登录，可以留空。
ssh_port="22"  ##【必填】SSH 端口。必须与各节点实际 SSHD 监听端口一致，否则 deploy.sh 无法远程分发和安装。
# 部署并发度。0 表示按节点数量自动并发；网络源或磁盘压力大时可改为 1 或 2。
parallel_jobs="3"

[os]
timezone="Asia/Shanghai"  ##设置系统时区
enable_chrony="true"   ##启用 chrony 时间同步服务
disable_transparent_hugepage="true"##禁用透明大页，PostgreSQL 生产环境常见建议
apply_sysctl="true" ##启用内核参数配置/etc/sysctl.d/99-postgresql-ha.conf
apply_limits="true"   ##启用postgres 用户资源限制
open_firewall_ports="true" ## 自动开放端口  
manage_selinux="false" ##是否在/etc/selinux/config文件中把SELinux 调成 permissive，并执行 setenforce 0

[etcd]
version="v3.6.12"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"  ##【必填】etcd 集群节点清单，格式为 节点名:IP。节点名会写入 /etc/etcd.conf.yml 的 name 和 initial-cluster，IP 必须是服务器真实地址。
client_port="2379"  ##etcd 客户端访问端口
peer_port="2380"  ##etcd 节点间通信端口
data_dir="/home/postgres/etcd"   ##etcd 数据目录
config_file="/home/postgres/etcd/etcd.conf.yml" ##etcd 配置文件路径
bin_dir="/home/postgres/etcd/bin" ##etcd、etcdctl、etcdutl 工具安装目录

[postgresql]
# PostgreSQL 实例身份和连接入口。这里的参数不是 postgresql.conf 参数。
version="17.10"
nodes="pg01:10.0.0.121,pg02:10.0.0.122,pg03:10.0.0.123"  ##【必填】PostgreSQL/Patroni 节点清单，格式为 节点名:IP。脚本会根据本机 IP 反查节点名，并写入 patroni.yml 的 name/connect_address。
port="5432"  ##【必填】PostgreSQL 服务端口。会写入 patroni.yml、环境变量、防火墙规则和备份脚本。
os_user="postgres"  ##【必填】PostgreSQL 运行用户。脚本会创建该用户，并用它运行 Patroni、PostgreSQL 和备份任务。
database="postgres"

[postgresql.install]
# 安装路径和存储路径。这里描述软件与文件布局，不会写入 postgresql.conf。
prefix="/home/postgres/pghome"  ##【必填】PostgreSQL 软件安装目录。脚本会把编译后的 postgres、psql、pg_config 等安装到该目录。
data_dir="/data/pgdata"  ##【必填】PostgreSQL 数据目录。会写入 patroni.yml 的 postgresql.data_dir，不能与已有不兼容实例混用。
# PostgreSQL 源码编译选项。--with-python 用于支持 PL/Python，需要 python3-devel。
# 生产上如需 lz4/zstd 压缩，可先补齐 lz4-devel/libzstd-devel 后再追加对应选项。
configure_options="--with-openssl --with-zlib --with-uuid=e2fs --with-python"

[postgresql.auth]
# 生产部署前必须修改这些默认密码。
superuser="postgres"
superpass=""  ##【必填】PostgreSQL 超级用户密码。脚本会强制检查，不能为空；会写入 patroni.yml 的 authentication.superuser.password。
replication_user="replicator"
replication_pass=""  ##【必填】流复制用户密码。脚本会强制检查，不能为空；用于主从复制认证。
rewind_user="rewind"
rewind_pass=""  ##【必填】pg_rewind 用户密码。脚本会强制检查，不能为空；用于旧主库回加入集群时执行 rewind。

[postgresql.conf]
# 这里的参数会进入 Patroni bootstrap.dcs.postgresql.parameters，
# 由 Patroni 管理并最终成为 PostgreSQL 配置。
listen_addresses="*"
max_connections="300"
shared_buffers="4GB"
effective_cache_size="12GB"
maintenance_work_mem="512MB"
work_mem="16MB"
wal_level="replica"
wal_log_hints="on"
max_wal_senders="10"
max_replication_slots="10"
wal_keep_size="2GB"
max_wal_size="8GB"
checkpoint_completion_target="0.9"
hot_standby="on"
hot_standby_feedback="on"
password_encryption="scram-sha-256"
shared_preload_libraries="pg_cron,pg_stat_statements"
pg_stat_statements.max="10000"
pg_stat_statements.track="all"
# pg_cron 只能在 cron.database_name 指定的数据库中创建 extension。
cron.database_name="postgres"
logging_collector="on"
log_directory="log"
log_filename="postgresql-%Y-%m-%d.log"
log_line_prefix="%m [%p] %u@%d %r %a "
log_min_duration_statement="1000"
archive_mode="on"
# archive_command 默认由 pg_probackup 管理。%p 是 WAL 文件路径，%f 是 WAL 文件名。
# -B 后面的目录必须与 [pg_probackup] backup_dir 保持一致。
archive_command="/usr/local/bin/pg_probackup archive-push -B /data/pgbak --instance pg17-ha --wal-file-path=%p --wal-file-name=%f"

[pg_probackup]
# pg_probackup 用于 WAL 归档和周期备份。源码包会下载到 packages/ 目录，
# 安装时会从该源码包编译安装。
version="2.5.16"
backup_dir="/data/pgbak"
instance="pg17-ha"
binary="/usr/local/bin/pg_probackup"   ## 将影响archive_command参数，修改时请同步修改archive_command参数
retention_redundancy="4"
retention_window="30"
cron_minute="30"
cron_hour="1"
# 每周几做全量备份。0 表示星期天，1-6 表示星期一到星期六。
full_backup_day="0"
# 每天非全量日执行的备份模式。PAGE 依赖 WAL 归档，适合增量备份。
incremental_mode="PAGE"
backup_user="postgres"

[pg_cron]
# pg_cron 用于数据库内定时任务。源码包会下载到 packages/ 目录，
# 安装时会从该源码包编译安装 PostgreSQL 扩展文件。
version="1.6.7"

[patroni]
version="3.0.4"
port="8008"   ##Patroni REST API 端口
home="/home/postgres/patroni"  ##Patroni配置目录/etc/patroni/patroni.yml、VIP callback
log_dir="/home/postgres/log"   

[patroni.dcs]
ttl="30"
loop_wait="10"
retry_timeout="10"
maximum_lag_on_failover="1048576"
use_pg_rewind="true"
use_slots="true"

[patroni.sync]
# “始终保持一个同步从库”的推荐配置：
#   synchronous_mode=true          开启同步复制管理
#   synchronous_mode_strict=true   没有可用同步从库时，主库写入会等待
#   synchronous_node_count=1       同时保持 1 个同步从库
#
# 注意：strict=true 是强一致性取向。如果所有可作为同步从库的节点都不可用，
# 写请求会阻塞，直到同步从库恢复或人工调整配置。
synchronous_mode="true"
synchronous_mode_strict="true"
synchronous_node_count="1"

[vip]
address="10.0.0.124"  ##【必填】数据库对外访问 VIP。Patroni Leader 会绑定该地址；如果留空，VIP 功能会被跳过，客户端需要自行处理主库入口。
cidr="24"  ##【必填】VIP 掩码长度。必须与业务网段匹配，例如 24 表示 255.255.255.0。
device="ens33"  ##【必填】绑定 VIP 的真实网卡名。必须是服务器上存在的网卡，可用 ip addr 查看；填错会导致 VIP 漂移失败。
label="pgvip"

[node.pg01]
# prefix=""
# data_dir=""
# etcd_data_dir=""
# patroni_home=""
# patroni_log_dir=""

[node.pg01.tags]
# nofailover=false 表示该节点允许被提升为主库；true 表示永不自动提升。
# noloadbalance=false 表示该节点允许承担读流量；true 表示不参与读负载。
# clonefrom=false 表示该节点不是优先的复制源；true 表示可优先作为新副本的基础备份来源。
# nosync=false 表示该节点允许被选为同步从库；true 表示该节点只能作为异步从库。
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg02]
# 留空表示继承 [postgresql.install]、[etcd] 和 [patroni] 的全局路径。

[node.pg02.tags]
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"

[node.pg03]
# 留空表示继承 [postgresql.install]、[etcd] 和 [patroni] 的全局路径。

[node.pg03.tags]
# 所有本地副本都可作为同步从库时保持 nosync=false。
# 如果该节点是跨机房容灾节点或链路延迟较高，不希望它影响主库提交延迟，
# 可设置 nosync=true，让它固定作为异步从库。
nofailover="false"
noloadbalance="false"
clonefrom="false"
nosync="false"
